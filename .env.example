# OCR API – copy to .env and fill in real values

# ── Authentication ────────────────────────────────────────────────────────────
API_KEY=change-me-to-a-long-random-string

# ── Output: Paperless-ngx ─────────────────────────────────────────────────────
ENABLE_PAPERLESS=true
PAPERLESS_URL=http://192.168.1.100:8000
PAPERLESS_TOKEN=your-paperless-api-token-here

# ── Output: rclone / OneDrive ─────────────────────────────────────────────────
ENABLE_RCLONE=false
RCLONE_TARGET=OneDrive:scanner/
# Path to rclone.conf on the HOST (mounted read-only into the container)
RCLONE_CONFIG_PATH=/root/.config/rclone/rclone.conf

# ── Output: local filesystem ──────────────────────────────────────────────────
ENABLE_FILESYSTEM=true
OUTPUT_DIR=/ocr-api/output

# ── OCR settings ──────────────────────────────────────────────────────────────
OCR_LANGUAGE=deu+eng+frk
TRASH_TMP_FILES=true

# ── AI Metadata extraction (OpenRouter) ───────────────────────────────────────
# When enabled, the OCR text is sent to an LLM to extract topic, correspondent,
# document type, and tags. The result renames the output file and pre-fills
# the structured fields in Paperless-ngx.
ENABLE_AI_METADATA=false
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key
# Model to use – see https://openrouter.ai/models for options
# claude-haiku-4.5 is fast and cheap; upgrade to claude-sonnet-4.5 for more accuracy
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
# Primary language of your documents (de = German, en = English)
AI_DOCUMENT_LANGUAGE=de

# ── Email notification (mutt + msmtp inside container) ────────────────────────
ENABLE_MAIL=false
MAIL_TO=recipient@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=sender@example.com
SMTP_PASSWORD=your-smtp-password
# SMTP_FROM defaults to SMTP_USER if left empty
SMTP_FROM=ocr-scanner@example.com
